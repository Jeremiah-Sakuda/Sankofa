# Gemini: use Vertex AI (GCP) or API key
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=false
# Must be from https://aistudio.google.com/apikey (not Google Cloud Console)
# Create key there, copy it, paste below with no quotes or extra spaces
GOOGLE_API_KEY=your-api-key-here

# Optional: override models. Narrative needs image+text (gemini-2.5-flash-image or gemini-3-pro-image-preview).
# GEMINI_PLANNING_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_TTS_MODEL=gemini-2.5-pro-preview-tts

# CORS: single origin or comma-separated list (production)
FRONTEND_URL=http://localhost:3000
# CORS_ORIGINS=https://your-app.run.app,https://www.example.com

# Set to production when deploying
ENVIRONMENT=development

# Session store: set USE_FIRESTORE=true in production (Cloud Run) so sessions survive restarts.
# Requires GOOGLE_CLOUD_PROJECT and Firestore API enabled; grant Cloud Run SA "Cloud Datastore User".
# USE_FIRESTORE=false
# FIRESTORE_SESSIONS_COLLECTION=sessions
